# Copy this file to `.env` (it is git-ignored). The local-dev defaults below work
# out of the box for the storage layer — no edits needed except your API key.

# ── Application settings (read by pydantic-settings, DATAMAN_ prefix) ──────────
DATAMAN_GOOGLE_PLACES_API_KEY=
DATAMAN_SEED_STORE_BACKEND=jsonl
# Seed path defaults (in code) to data/raw/google_places/restaurants_seed.jsonl —
# leave unset to use it; only override if you keep the seed file elsewhere.

# MongoDB — document system of record.
# Local dev runs WITHOUT auth (localhost only). Do not use this as-is in production;
# enable authentication before exposing Mongo beyond your machine.
DATAMAN_MONGO_URI=mongodb://localhost:27017
DATAMAN_MONGO_DB=dataman
DATAMAN_MONGO_COLLECTION=restaurants_seed

# ClickHouse — columnar analytics. Placeholders, unused until the ETL exists
# (see docs/etl-design.md). Uncomment when the mongo -> clickhouse ETL lands.
# DATAMAN_CLICKHOUSE_HOST=localhost
# DATAMAN_CLICKHOUSE_PORT=8123   # HTTP interface (used by Python drivers); 9000 is native TCP
# DATAMAN_CLICKHOUSE_DB=dataman

# ── Docker Compose settings (host port overrides; NOT DATAMAN_ app settings) ───
# These live in a separate namespace: Compose reads them to map container ports
# to your host. Change one only if that port is already in use on your machine.
MONGO_PORT=27017
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
